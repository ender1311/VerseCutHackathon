# ── Bible provider (client-visible) ───────────────────────────────────────────
# 'mock' | 'youversion' (recommended) | 'api.bible'
NEXT_PUBLIC_BIBLE_PROVIDER=youversion
# Default version id (YouVersion: 111=NIV, 3034=BSB, 1=KJV)
NEXT_PUBLIC_BIBLE_DEFAULT_VERSION=111

# ── YouVersion Platform API (server-side secret) ─────────────────────────────
# Injected by the /api/yvp route handler; never shipped to the browser.
# Get a key at https://platform.youversion.com
YV_PLATFORM_API_KEY=

# ── API.Bible (only if NEXT_PUBLIC_BIBLE_PROVIDER=api.bible) ──────────────────
NEXT_PUBLIC_BIBLE_API_KEY=

# ── WorkOS AuthKit (Phase 2 — multi-user auth) ───────────────────────────────
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# WORKOS_COOKIE_PASSWORD=
# WORKOS_REDIRECT_URI=http://localhost:3000/callback
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
